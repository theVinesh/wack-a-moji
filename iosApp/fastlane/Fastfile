default_platform(:ios)

def ci?
  ENV["CI"].to_s == "true"
end

def env_present?(key)
  !ENV[key].to_s.strip.empty?
end

def ios_app_identifier
  ENV["IOS_APP_IDENTIFIER"].to_s.strip.empty? ? "com.thevinesh.wackamoji" : ENV["IOS_APP_IDENTIFIER"].strip
end

def ios_team_id
  ENV["IOS_TEAM_ID"].to_s.strip.empty? ? "9S95C26JN6" : ENV["IOS_TEAM_ID"].strip
end

def missing_build_requirements
  %w[
    MATCH_GIT_URL
    MATCH_PASSWORD
    APP_STORE_CONNECT_API_KEY_KEY_ID
    APP_STORE_CONNECT_API_KEY_ISSUER_ID
    APP_STORE_CONNECT_API_KEY_KEY
  ].reject { |key| env_present?(key) }
end

def missing_upload_requirements
  %w[
    APP_STORE_CONNECT_API_KEY_KEY_ID
    APP_STORE_CONNECT_API_KEY_ISSUER_ID
    APP_STORE_CONNECT_API_KEY_KEY
  ].reject { |key| env_present?(key) }
end

def app_store_api_key
  app_store_connect_api_key(
    key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
    issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
    key_content: ENV["APP_STORE_CONNECT_API_KEY_KEY"],
    is_key_content_base64: true
  )
end

def match_options(api_key)
  options = {
    type: "appstore",
    readonly: ci?,
    app_identifier: [ios_app_identifier],
    team_id: ios_team_id,
    api_key: api_key
  }
  options[:git_url] = ENV["MATCH_GIT_URL"]
  options[:git_basic_authorization] = ENV["MATCH_GIT_BASIC_AUTHORIZATION"] if env_present?("MATCH_GIT_BASIC_AUTHORIZATION")
  options
end

platform :ios do
  desc "Sync App Store metadata into fastlane/metadata"
  lane :sync_metadata do
    shared_path = File.expand_path("../../store_metadata", __dir__)
    ios_metadata_path = File.join(shared_path, "ios", "metadata")
    metadata_path = File.expand_path("metadata", __dir__)
    shared_locale_path = File.join(shared_path, "en-US")
    locale_path = File.join(metadata_path, "en-US")

    sh "rm -rf '#{metadata_path}'"
    sh "mkdir -p '#{metadata_path}'"
    sh "cp -R '#{ios_metadata_path}/.' '#{metadata_path}/'"
    sh "mkdir -p '#{locale_path}'"
    sh "cp '#{File.join(shared_locale_path, 'name.txt')}' '#{File.join(locale_path, 'name.txt')}'"
    sh "cp '#{File.join(shared_locale_path, 'description.txt')}' '#{File.join(locale_path, 'description.txt')}'"
  end

  desc "Sync shared App Store screenshots into fastlane/screenshots"
  lane :sync_screenshots do
    shared_screenshots_path = File.expand_path("../../store_metadata/assets/screenshots/ios/en-US", __dir__)
    screenshots_path = File.expand_path("screenshots", __dir__)
    dest_path = File.join(screenshots_path, "en-US")

    sh "rm -rf '#{screenshots_path}'"

    if Dir.exist?(shared_screenshots_path)
      sh "mkdir -p '#{dest_path}'"
      sh "cp -R '#{shared_screenshots_path}/.' '#{dest_path}/'"
    end
  end

  desc "Build the TestFlight-ready iOS release artifact"
  lane :build_release_artifact do
    missing = missing_build_requirements
    if missing.any?
      UI.user_error!("Missing Apple-side prerequisites or GitHub secrets for iOS release build: #{missing.join(', ')}")
    end

    setup_ci if ci?

    api_key = app_store_api_key

    match(**match_options(api_key))

    increment_build_number(
      xcodeproj: "iosApp.xcodeproj",
      build_number: ENV["GITHUB_RUN_NUMBER"] || "1"
    )

    build_app(
      project: "iosApp.xcodeproj",
      scheme: "iosApp",
      clean: true,
      export_method: "app-store",
      output_directory: "build/ci-release",
      output_name: "Wack-A-Moji.ipa"
    )
  end

  desc "Upload a prebuilt iOS release artifact to TestFlight"
  lane :deploy do
    ipa_path = ENV["IOS_IPA_PATH"]
    UI.user_error!("IOS_IPA_PATH must point to a readable IPA") if ipa_path.to_s.empty? || !File.exist?(ipa_path)

    missing = missing_upload_requirements
    if missing.any?
      UI.user_error!("Missing App Store Connect API credentials for iOS upload: #{missing.join(', ')}")
    end

    api_key = app_store_api_key

    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Sync App Store metadata and screenshots without uploading a new build"
  lane :sync_listing do
    missing = missing_upload_requirements
    if missing.any?
      UI.user_error!("Missing App Store Connect API credentials for iOS listing sync: #{missing.join(', ')}")
    end

    api_key = app_store_api_key

    sync_metadata
    sync_screenshots

    metadata_path = File.expand_path("metadata", __dir__)
    screenshots_path = File.expand_path("screenshots", __dir__)

    deliver_options = {
      api_key: api_key,
      app_identifier: ios_app_identifier,
      platform: "ios",
      metadata_path: metadata_path,
      skip_binary_upload: true,
      skip_app_version_update: true,
      submit_for_review: false,
      run_precheck_before_submit: false,
      force: true
    }

    if Dir.exist?(screenshots_path)
      ENV["FASTLANE_ENABLE_BETA_DELIVER_SYNC_SCREENSHOTS"] = "true"
      deliver_options[:screenshots_path] = screenshots_path
      deliver_options[:sync_screenshots] = true
    else
      deliver_options[:skip_screenshots] = true
    end

    deliver(**deliver_options)
  end
end
