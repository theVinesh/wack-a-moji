default_platform(:android)

platform :android do
  desc "Upload a prebuilt Android App Bundle to Google Play"
  lane :deploy do
    play_config_path = ENV["ANDROID_PLAY_CONFIG_JSON_PATH"]
    UI.user_error!("ANDROID_PLAY_CONFIG_JSON_PATH must point to a readable Google Play service account json key") if play_config_path.to_s.empty? || !File.exist?(play_config_path)

    aab_path = ENV["ANDROID_AAB_PATH"]
    UI.user_error!("ANDROID_AAB_PATH must point to a readable Android App Bundle") if aab_path.to_s.empty? || !File.exist?(aab_path)

    release_status = ENV.fetch("ANDROID_PLAY_RELEASE_STATUS", "draft")

    upload_to_play_store(
      track: ENV.fetch("ANDROID_PLAY_TRACK", "internal"),
      release_status: release_status,
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_changelogs: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      aab: aab_path
    )
  end

  desc "Sync shared metadata to fastlane folder"
  lane :sync_metadata do
    shared_path = File.expand_path("../../store_metadata", __dir__)
    metadata_path = File.expand_path("metadata/android", __dir__)
    locale_path = File.join(metadata_path, "en-US")
    images_path = File.join(locale_path, "images")
    screenshots_source_path = File.join(shared_path, "assets", "screenshots", "android", "en-US", "phoneScreenshots")
    phone_screenshots_path = File.join(images_path, "phoneScreenshots")

    sh "rm -rf '#{metadata_path}'"
    sh "mkdir -p '#{images_path}'"
    sh "cp '#{File.join(shared_path, 'en-US', 'name.txt')}' '#{File.join(locale_path, 'title.txt')}'"
    sh "cp '#{File.join(shared_path, 'en-US', 'short_description.txt')}' '#{File.join(locale_path, 'short_description.txt')}'"
    sh "cp '#{File.join(shared_path, 'en-US', 'description.txt')}' '#{File.join(locale_path, 'full_description.txt')}'"
    sh "cp '#{File.join(shared_path, 'assets', 'feature_graphic.png')}' '#{File.join(images_path, 'featureGraphic.png')}'"
    sh "cp '#{File.join(shared_path, 'assets', 'icon_512.png')}' '#{File.join(images_path, 'icon.png')}'"

    if Dir.exist?(screenshots_source_path)
      sh "mkdir -p '#{phone_screenshots_path}'"
      sh "cp -R '#{screenshots_source_path}/.' '#{phone_screenshots_path}/'"
    end
  end

  desc "Sync Play Store metadata, images, and screenshots without uploading a new binary"
  lane :sync_listings do
    play_config_path = ENV["ANDROID_PLAY_CONFIG_JSON_PATH"]
    UI.user_error!("ANDROID_PLAY_CONFIG_JSON_PATH must point to a readable Google Play service account json key") if play_config_path.to_s.empty? || !File.exist?(play_config_path)

    sync_metadata

    metadata_path = File.expand_path("metadata/android", __dir__)

    upload_to_play_store(
      track: ENV.fetch("ANDROID_PLAY_TRACK", "internal"),
      metadata_path: metadata_path,
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_changelogs: true,
      sync_image_upload: true
    )
  end
end
